	<http:listener-config name="HTTP_Listener_config" doc:name="HTTP_Listener_config" doc:id="282f87d1-3f8d-4c8f-86a9-3fc874cf7afb">
		<http:listener-connection host="${http.host}" port="${http.port}" />
	</http:listener-config>
	<db:config name="Database_Config" doc:name="Database_Config" doc:id="32b96b46-6c71-49d7-a54d-b86420403dc0" >
		<db:generic-connection url="${db.url}" driverClassName="${db.driver-class-name}" user="${db.user}" password="${secure::db.password}" useXaTransactions="true">
			<reconnection >
				<reconnect frequency="120000" count="5" />
			</reconnection>
		</db:generic-connection>
	</db:config>
	<configuration doc:name="Configuration" doc:id="d9ec02a0-bbb3-484c-a8e6-940ebd511891" defaultErrorHandler-ref="allErrorHandlerr"/>
	<salesforce:sfdc-config name="Salesforce_Config" doc:name="Salesforce Config" doc:id="de934198-2749-45ad-b731-4e309f7f40b6" >
		<salesforce:basic-connection username="${sf.username}" password="${secure::sf.password}" securityToken="${sf.security-token}" url="${sf.authorization-url}" />
	</salesforce:sfdc-config>
	<sftp:config name="SFTP_Config" doc:name="SFTP Config" doc:id="e49440de-33a9-4703-ad26-45f80a229e7e" >
		<sftp:connection host="localhost" username="tester" password="password" workingDir="/mule/input">
